# Runtime mode
# simulation | fabric | ethereum
BLOCKCHAIN_MODE=simulation

# Fabric settings (used when BLOCKCHAIN_MODE=fabric)
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_ORDERER_ENDPOINT=localhost:7050
FABRIC_CHANNEL_NAME=auditchannel
FABRIC_CHAINCODE_NAME=audit_trail
FABRIC_MSP_ID=HospitalMSP
FABRIC_TLS_ENABLED=true
FABRIC_TLS_CERT_PATH=

# Dashboard runtime
APP_HOST=0.0.0.0
APP_PORT=5000
FLASK_DEBUG=true

# Verification defaults
VERIFICATION_MIN_VERIFIERS=3
VERIFICATION_APPROVAL_THRESHOLD=70.0

# Pipeline defaults
DEFAULT_REAL_DATA=data/raw/adult.csv
DEFAULT_TARGET_COLUMN=income
